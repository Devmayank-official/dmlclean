# DMLClean Environment Variables
# Copy this file to .env and customize as needed

# Configuration
# DMLCLEAN_CONFIG=/path/to/config.toml

# Logging
# DMLCLEAN_LOG_LEVEL=INFO
# DMLCLEAN_LOG_FILE=/path/to/dmlclean.log

# General Settings
# DMLCLEAN_GENERAL_DEFAULT_SCAN_MODE=fast
# DMLCLEAN_GENERAL_DEFAULT_CLEAN_MODE=dry-run
# DMLCLEAN_GENERAL_DEFAULT_PROFILE=developer
# DMLCLEAN_GENERAL_CONFIRM_THRESHOLD_MB=100
# DMLCLEAN_GENERAL_CONFIRM_THRESHOLD_FILES=1000
# DMLCLEAN_GENERAL_MAX_WORKERS=0

# Scanner Settings
# DMLCLEAN_SCANNER_FOLLOW_SYMLINKS=false
# DMLCLEAN_SCANNER_MAX_DEPTH=0
# DMLCLEAN_SCANNER_LARGE_FILE_THRESHOLD_MB=500
# DMLCLEAN_SCANNER_ENABLE_SMART_SCAN=true

# Cleaner Settings
# DMLCLEAN_CLEANER_ENABLE_INCREMENTAL=true
# DMLCLEAN_CLEANER_MIN_SIZE_MB=0
# DMLCLEAN_CLEANER_MIN_AGE_DAYS=0
# DMLCLEAN_CLEANER_NODE_MODULES_MIN_AGE_DAYS=30

# Protected Zone Settings
# DMLCLEAN_PROTECTED_ZONE_ENABLED=true
# DMLCLEAN_PROTECTED_ZONE_PROTECT_GIT_DIRS=true
# DMLCLEAN_PROTECTED_ZONE_PROTECT_VENVS=true
# DMLCLEAN_PROTECTED_ZONE_PROTECT_RECENT_DAYS=1

# Notifications
# DMLCLEAN_NOTIFICATIONS_ENABLED=true
# DMLCLEAN_NOTIFICATIONS_ON_SCAN_COMPLETE=true
# DMLCLEAN_NOTIFICATIONS_ON_CLEAN_COMPLETE=true
# DMLCLEAN_NOTIFICATIONS_ON_ERROR=true

# Scheduling
# DMLCLEAN_SCHEDULING_ENABLED=false
# DMLCLEAN_SCHEDULING_BACKEND=apscheduler

# History
# DMLCLEAN_HISTORY_ENABLED=true
# DMLCLEAN_HISTORY_MAX_ENTRIES=100

# Debug
# DMLCLEAN_DEBUG=true
# DMLCLEAN_TEST_MODE=false

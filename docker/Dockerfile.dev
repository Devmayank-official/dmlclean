# DMLClean Development Dockerfile
# Multi-stage build for development with hot-reload support

# =============================================================================
# Stage 1: Base - Common dependencies
# =============================================================================
FROM python:3.12-slim AS base

LABEL maintainer="DML Labs <dmlclean@dmlabs.dev>"
LABEL description="DMLClean Development Environment"
LABEL version="0.1.0"

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libffi-dev \
    && rm -rf /var/lib/apt/lists/*

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# =============================================================================
# Stage 2: Dependencies - Install Python packages
# =============================================================================
FROM base AS dependencies

# Copy only dependency files first (for better caching)
COPY pyproject.toml .

# Install hatch for environment management
RUN pip install --no-cache-dir hatch

# Create hatch environment
RUN hatch env create

# =============================================================================
# Stage 3: Development - Full development environment
# =============================================================================
FROM dependencies AS dev

# Install development tools
RUN pip install --no-cache-dir \
    pyinstaller \
    pre-commit \
    mkdocs \
    mkdocs-material

# Copy source code (will be mounted as volume in development)
COPY src/ src/
COPY tests/ tests/
COPY Makefile .
COPY dmlclean.spec .

# Create non-root user
RUN groupadd -r dmlclean && useradd -r -g dmlclean dmlclean

# Set ownership
RUN chown -R dmlclean:dmlclean /app

# Switch to non-root user
USER dmlclean

# Default command
CMD ["bash"]

# =============================================================================
# Usage:
# =============================================================================
# Build:
#   docker build -f docker/Dockerfile.dev -t dmlclean:dev .
#
# Run with hot-reload:
#   docker run -it -v $(pwd)/src:/app/src -v $(pwd)/tests:/app/tests dmlclean:dev
#
# Docker Compose:
#   docker-compose up dmlclean-dev
#
# Run tests:
#   docker-compose run test
# =============================================================================
